<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>
<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-viewport-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.formsapp.contract.Contract1Controller">
    <stylesheets>
        <URL value="@/org/example/formsapp/styles.css" />
    </stylesheets>

    <VBox spacing="20.0" style="-fx-background-color: #f8f9fa;">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <VBox spacing="5.0">
            <Label text="Umowa Zlecenia" textFill="#2c3e50">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Label>
        </VBox>

        <TitledPane animated="false" collapsible="false" text="Dane umowy">
            <GridPane hgap="15.0" style="-fx-padding: 15; -fx-background-color: white;" vgap="12.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                </columnConstraints>
                <VBox spacing="5.0" GridPane.columnIndex="0">
                    <Label text="Numer umowy" />
                    <TextField fx:id="nrUmowy" styleClass="my-text-field" />
                </VBox>
                <VBox spacing="5.0" GridPane.columnIndex="1">
                    <Label text="Umowa zawarta w" />
                    <TextField fx:id="miejsceZawarcia" styleClass="my-text-field" />
                </VBox>
                <VBox spacing="5.0" GridPane.columnIndex="2">
                    <Label text="Data zawarcia" />
                    <DatePicker fx:id="dataZawarcia" maxWidth="1.7976931348623157E308" styleClass="my-text-field" />
                </VBox>
            </GridPane>
        </TitledPane>

        <HBox spacing="15.0">
            <TitledPane animated="false" collapsible="false" text="Zleceniodawca" HBox.hgrow="ALWAYS">
                <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: white;">
                    <Label text="Imię i nazwisko" />
                    <TextField fx:id="imieNazwiskoZd" styleClass="my-text-field" />
                    <Label text="Nazwa firmy" />
                    <TextField fx:id="nazwaZd" styleClass="my-text-field" />
                    <Label text="Adres" />
                    <TextField fx:id="adresZd" styleClass="my-text-field" />
                </VBox>
            </TitledPane>

            <TitledPane animated="false" collapsible="false" text="Zleceniobiorca" HBox.hgrow="ALWAYS">
                <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: white;">
                    <Label text="Imię i nazwisko" />
                    <TextField fx:id="imieNazwiskoZb" styleClass="my-text-field" />
                    <Label text="Nazwa firmy" />
                    <TextField fx:id="nazwaZb" styleClass="my-text-field" />
                    <Label text="Adres" />
                    <TextField fx:id="adresZb" styleClass="my-text-field" />
                </VBox>
            </TitledPane>
        </HBox>

        <TitledPane animated="false" collapsible="false" text="Szczegóły umowy">
            <VBox spacing="15.0" style="-fx-padding: 15; -fx-background-color: white;">
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Okres trwania (od)" />
                        <DatePicker fx:id="okresOd" maxWidth="1.7976931348623157E308" styleClass="my-text-field" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Okres trwania (do)" />
                        <DatePicker fx:id="okresDo" maxWidth="1.7976931348623157E308" styleClass="my-text-field" />
                    </VBox>
                </HBox>
                <Label text="Opis czynności" />
                <TextField fx:id="opisCzynnosci" styleClass="my-text-field" />
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Stawka za godzinę (brutto)" />
                        <TextField fx:id="stawkaH" styleClass="my-text-field" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Dzień wypłaty (max)" />
                        <TextField fx:id="wyplataDataMax" styleClass="my-text-field" />
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Okres wypowiedzenia (dni)" />
                        <TextField fx:id="okresWypow" styleClass="my-text-field" />
                    </VBox>
                </HBox>
            </VBox>
        </TitledPane>

        <fx:include fx:id="buttonBar" source="../button_bar.fxml" />
    </VBox>
</ScrollPane>
